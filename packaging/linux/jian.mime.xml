<?xml version="1.0" encoding="UTF-8"?>
<!--
  XDG MIME definition for the .op design file format. Pair with
  `packaging/linux/jian.desktop` so file double-click on a `.op` opens
  in `jian player`. Installs into `~/.local/share/mime/packages/`
  (or `/usr/share/mime/packages/` for system-wide installs) and
  is picked up by `update-mime-database`.
-->
<!--
  `*.op.pack` is intentionally NOT in the glob list: the
  `DesktopHost::open_file` entry-point currently reads its
  argument as a raw `.op` JSON and would fail on a ZIP pack.
  Restore the second `<glob>` line once `open_file` learns to
  detect `.op.pack` and route through `jian unpack` first.
-->
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">
  <mime-type type="application/x-jian-op">
    <comment>Jian / OpenPencil design file</comment>
    <glob pattern="*.op"/>
    <icon name="jian"/>
  </mime-type>
</mime-info>
