<?xml version="1.0" encoding="UTF-8"?>
<!--
  XDG MIME definition for the .op design file format. Pair with
  `dist/linux/jian.desktop` so file double-click on a `.op` opens
  in `jian player`. Installs into `~/.local/share/mime/packages/`
  (or `/usr/share/mime/packages/` for system-wide installs) and
  is picked up by `update-mime-database`.
-->
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">
  <mime-type type="application/x-jian-op">
    <comment>Jian / OpenPencil design file</comment>
    <glob pattern="*.op"/>
    <glob pattern="*.op.pack"/>
    <icon name="jian"/>
  </mime-type>
</mime-info>
